// The Prisma schema defines your data models and database connection:

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

// datasource block tells the schema where the models are backed.
datasource db {
  provider = "postgresql"
}

// Enums (write all enums first, models reference them)

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_WON
  BET_REFUND
  BONUS
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum EventStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
}

enum EventResult {
  HOME_WIN
  AWAY_WIN
  DRAW
}

enum NotificationType {
  BET_SETTLED
  DEPOSIT_COMPLETE
  WITHDRAWAL_COMPLETE
  PROMO
  KYC_APPROVED
  KYC_REJECTED
}


enum BetType {
  SINGLE
  MULTI // accumulator or pirate parlay
  SYSTEM // system bet (e.g. 2-from-3)
}

enum LegStatus {
  PENDING
  WON
  LOST
  VOID
  PUSHED
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
  CASHED_OUT
  PARTIALLY_SETTLED
}


// Models
// ─── USER & AUTH ───────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  dateOfBirth  DateTime?
  phone        String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  kycStatus    KycStatus @default(PENDING)
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  wallet        Wallet?
  bets          Bet[]
  notifications Notification[]
  transactions  Transaction[]
  sessions      Session[]
  favourites    FavouriteSport[]

  @@index([email])
  @@index([username])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

// ─── WALLET & TRANSACTIONS ─────────────────────────────
model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  currency  String   @default("AUD")
  createdAt DateTime @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id            String          @id @default(cuid())
  walletId      String
  userId        String
  betId         String?
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  balanceBefore Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2)
  status        PaymentStatus   @default(PENDING)
  metadata      Json?
  reference     String?
  createdAt     DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bet    Bet?   @relation(fields: [betId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([betId])
  @@index([type])
  @@index([createdAt])
}

// ─── SPORTS & EVENTS ───────────────────────────────────
model Sport {
  id          String  @id // OddsAPI slug e.g. "americanfootball_nfl"
  group       String? // e.g. "Soccer" or "Aussie Rules"
  title       String // e.g. "AFL"
  description String?
  isActive    Boolean @default(true)
  iconUrl     String?

  hasOutrights Boolean          @default(false)
  favourites   FavouriteSport[]
  events       Event[]
}

model FavouriteSport {
  userId  String
  sportId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@id([userId, sportId])
}

model Team {
  id         String  @id @default(cuid())
  name       String  @unique
  homeEvents Event[] @relation("HomeTeam")
  awayEvents Event[] @relation("AwayTeam")
}

model Event {
  id           String      @id @default(cuid())
  externalId   String      @unique
  sportId      String
  homeTeamId   String
  homeTeam     Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId   String
  awayTeam     Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  commenceTime DateTime
  status       EventStatus @default(UPCOMING)
  homeScore    Int?
  awayScore    Int?
  result       EventResult?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  sport         Sport          @relation(fields: [sportId], references: [id])
  oddsSnapshots OddsSnapshot[]
  betLegs       BetLeg[]

  @@index([sportId])
  @@index([commenceTime])
  @@index([status])
  @@index([sportId, commenceTime])
}

model OddsSnapshot {
  id        String   @id @default(cuid())
  eventId   String
  bookmaker String // "sportsbet", "tab", etc
  market    String // "h2h", "lines", "totals"
  outcomes  Json // array of { name, price, point? }
  fetchedAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, market])
  @@index([eventId, bookmaker, market])
  @@index([fetchedAt])
}


// ─── BETTING ────────────────────────────────────────────
model Bet {
  id              String         @id @default(cuid())
  userId          String
  type            BetType
  stake           Decimal        @db.Decimal(12, 2)
  potentialPayout Decimal        @db.Decimal(12, 2)
  actualPayout    Decimal?       @db.Decimal(12, 2)
  totalOdds       Decimal        @db.Decimal(10, 4)
  status          BetStatus      @default(PENDING)
  placedAt        DateTime       @default(now())
  settledAt       DateTime?
  user         User          @relation(fields: [userId], references: [id])
  legs         BetLeg[]
  transactions Transaction[]

  @@index([userId])
  @@index([status])
  @@index([userId, placedAt])
}

model BetLeg {
  id        String     @id @default(cuid())
  betId     String
  eventId   String
  market    String // "h2h", "totals"
  selection String // team name or "overs/unders"
  odds      Decimal    @db.Decimal(10, 4)
  line      Decimal?   @db.Decimal(6, 2) // spread/total line 
  bookmaker String // which bookie odds used
  status    LegStatus @default(PENDING)

  bet   Bet   @relation(fields: [betId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id])

  @@index([betId])
  @@index([eventId])
  @@index([eventId, status])
}


// ─── NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}
