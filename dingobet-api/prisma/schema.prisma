// The Prisma schema defines your data models and database connection:

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

// datasource block tells the schema where the models are backed.
datasource db {
  provider = "postgresql"
}

// Enums (write all enums first, models reference them)

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_WON
  BET_REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum EventStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum MarketType {
  H2H
  SPREADS
  TOTALS
}

enum BetType {
  SINGLE
  MULTI
}

enum BetStatus {
  PENDING
  WON
  LOST
  CANCELLED
}

enum SelectionResult {
  WON
  LOST
  CANCELLED
}

// Models
// GROUP 1: Auth
model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  username      String         @unique
  passwordHash  String?
  name          String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  wallet        Wallet?
  bets          Bet[]
  transactions  Transaction[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// GROUP 2: Wallet
//  - Wallet — id, userId FK (unique = one-to-one), balance Decimal(12,2), createdAt, updatedAt
// - Transaction — id, walletId FK, type, amount Decimal(12,2), status, description?, betId FK?, createdAt
model Wallet {
  id           Int           @id @default(autoincrement())
  userId       Int           @unique
  user         User          @relation(fields: [userId], references: [id])
  balance      Decimal       @default(0) @db.Decimal(19, 4)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id          Int               @id @default(autoincrement())
  walletId    Int
  wallet      Wallet            @relation(fields: [walletId], references: [id])
  userId      Int
  user        User              @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Decimal           @db.Decimal(19, 4)
  status      TransactionStatus @default(PENDING)
  description String?
  betId       Int?
  bet         Bet?              @relation(fields: [betId], references: [id])
  createdAt   DateTime          @default(now())
}

//  GROUP 3: Odds Data (from The Odds API)
// - Sport — id, key (unique), group, title, active Boolean
// - Event — id, externalId (unique), sportId FK, homeTeam, awayTeam, commenceTime, status, homeScore?, awayScore?, createdAt, updatedAt
// - Market — id, eventId FK, type MarketType — @@unique([eventId, type])
// - Outcome — id, marketId FK, name, price Decimal(10,4), point Decimal(6,2)?
model Sport {
  id           Int     @id @default(autoincrement())
  key          String  @unique // OddsAPI slug e.g. "english_soccer" etc
  group        String // e.g. "Soccer" or "Aussie Rules"
  title        String
  description  String?
  active       Boolean @default(true)
  hasOutrights Boolean @default(false)
  events       Event[]
}

model Team {
  id         Int     @id @default(autoincrement())
  name       String  @unique
  homeEvents Event[] @relation("HomeTeam")
  awayEvents Event[] @relation("AwayTeam")
}

model Event {
  id           Int         @id @default(autoincrement())
  externalId   String      @unique
  sportId      Int
  sport        Sport       @relation(fields: [sportId], references: [id])
  homeTeamId   Int
  homeTeam     Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId   Int
  awayTeam     Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  commenceTime DateTime
  status       EventStatus @default(UPCOMING)
  homeScore    Int?
  awayScore    Int?
  markets      Market[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Market {
  id       Int        @id @default(autoincrement())
  eventId  Int
  event    Event      @relation(fields: [eventId], references: [id])
  type     MarketType
  outcomes Outcome[]

  @@unique([eventId, type])
}

model Outcome {
  id            Int            @id @default(autoincrement())
  marketId      Int
  market        Market         @relation(fields: [marketId], references: [id])
  name          String
  price         Decimal        @db.Decimal(10, 4)
  point         Decimal?       @db.Decimal(6, 2)
  betSelections BetSelection[]
}

//  Group 4: Bets
// - Bet — id, userId FK, type BetType, stake Decimal(12,2), potentialPayout Decimal(12,2), actualPayout Decimal(12,2)?, odds Decimal(10,4),
// status BetStatus, placedAt, settledAt?
// - BetSelection — id, betId FK, outcomeId FK, odds Decimal(10,4), result SelectionResult?
model Bet {
  id              Int            @id @default(autoincrement())
  userId          Int
  user            User           @relation(fields: [userId], references: [id])
  type            BetType
  stake           Decimal        @db.Decimal(10, 4)
  potentialPayout Decimal        @db.Decimal(12, 2)
  actualPayout    Decimal?       @db.Decimal(10, 4)
  odds            Decimal        @db.Decimal(12, 2)
  status          BetStatus      @default(PENDING)
  placedAt        DateTime       @default(now())
  settledAt       DateTime?
  selections      BetSelection[]
  transactions    Transaction[]
}

model BetSelection {
  id        Int              @id @default(autoincrement())
  betId     Int
  bet       Bet              @relation(fields: [betId], references: [id])
  outcomeId Int
  outcome   Outcome          @relation(fields: [outcomeId], references: [id])
  odds      Decimal          @db.Decimal(10, 4)
  result    SelectionResult?
}
