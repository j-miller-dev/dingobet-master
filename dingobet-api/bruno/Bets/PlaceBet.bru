meta {
  name: Place Bet
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/bets
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "legs": [
      {
        "eventId": "your-event-id-here",
        "bookmaker": "neds",
        "market": "h2h",
        "selection": "Melbourne Victory"
      }
    ],
    "stake": 25.00
  }
}
